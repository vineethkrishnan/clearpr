# ===========================================================================
# GitHub App (required)
# ===========================================================================
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ===========================================================================
# LLM Provider
# ===========================================================================
# Provider: anthropic | openai | ollama | mistral | gemini
LLM_PROVIDER=anthropic
# API key (not required for ollama)
LLM_API_KEY=
# Model override (defaults per provider: claude-sonnet-4-20250514, gpt-4o, llama3, mistral-large-latest, gemini-2.5-pro)
# LLM_MODEL=
# Base URL override (required for ollama, optional for OpenAI-compatible)
# LLM_BASE_URL=http://localhost:11434

# ===========================================================================
# Embedding
# ===========================================================================
# Provider: voyage | local
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
# EMBEDDING_MODEL=voyage-3-lite

# ===========================================================================
# Database & Redis (required)
# ===========================================================================
DATABASE_URL=postgresql://clearpr:clearpr@localhost:5432/clearpr
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ===========================================================================
# Application
# ===========================================================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ===========================================================================
# Review Tuning
# ===========================================================================
# MAX_DIFF_LINES=5000
# MAX_FILE_SIZE_KB=100
# HISTORY_DEPTH=200
# REVIEW_CONCURRENCY=3
# SIMILARITY_THRESHOLD=0.75
# DEBOUNCE_WINDOW_MS=30000
