{
  "moduleFileExtensions": ["js", "json", "ts"],
  "setupFiles": ["./setup-env.ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.\\.?/.*)\\.js$": "$1"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(octokit|@octokit|universal-user-agent|before-after-hook|universal-github-app-jwt)/)"
  ]
}
